extends ../../layouts/base

block content
  - var aboutLabel    = locale === 'en' ? 'About' : locale === 'es' ? 'Acerca de' : 'À propos'
  - var partnersLabel = locale === 'en' ? 'Our partners' : locale === 'es' ? 'Nuestros socios' : 'Merci à nos partenaires'
  - var cat = t.projects.categories.autres

  header.page-header
    .container
      h1 #{cat.title}
      p #{cat.subtitle}

  section.project-detail
    .container
      .project-detail-layout

        //- Gauche : description + partenaires
        .project-desc
          h2.detail-section-title #{aboutLabel}
          p.typed-text(data-text=cat.description)
          if cat.partners && cat.partners.length
            .partners-section
              h3.partners-title #{partnersLabel}
              .partners-grid
                each partner in cat.partners
                  .partner-card
                    if partner.logo
                      img(src=partner.logo alt=partner.name)
                    else
                      .partner-logo-placeholder 🤝
                    span.partner-name #{partner.name}

        //- Droite : carte vintage 2026
        .project-photos
          .vintage-cards-row
            .vintage-card(id='openAutres2026' style='cursor:pointer')
              .vintage-card-inner
                .vintage-photo-area
                  img(src='/images/realisations/autres/ottawa-2023.png' alt='Autres' onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'")
                  .coming-soon-card(style='display:none')
                    span.coming-soon-camera 📷
                    .coming-soon-text
                      span À venir
                      span.dots
                        span .
                        span .
                        span .
                .vintage-card-footer
                  span 2019-2023
              .vintage-card-shine

  //- Shadowbox
  .album-backdrop(id='autresBackdrop')
  .album-modal(id='autresModal')
    button.album-close(id='autresClose' type='button') ✕

    each section, si in cat.sections || []
      .album-section
        h3.album-section-title 📸 #{section.title}
        .album-grid
          each photo, i in section.photos
            .album-thumb(
              data-src=photo.src
              data-caption=photo.caption
              data-section=`autres-${si}`
              data-index=i
            )
              img(src=photo.src alt=photo.caption)

  //- Lightbox
  .lightbox(id='lightbox')
    button.lightbox-close(id='lightboxClose') ✕
    button.lightbox-prev(id='lightboxPrev') ‹
    button.lightbox-next(id='lightboxNext') ›
    .lightbox-content(id='lightboxContent')