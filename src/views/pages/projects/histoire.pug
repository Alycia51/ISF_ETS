extends ../../layouts/base

block content
  - var aboutLabel    = locale === 'en' ? 'About' : locale === 'es' ? 'Acerca de' : 'À propos'
  - var partnersLabel = locale === 'en' ? 'Our partners' : locale === 'es' ? 'Nuestros socios' : 'Merci à nos partenaires'
  - var galaLabel     = locale === 'en' ? 'Gala' : locale === 'es' ? 'Gala' : 'Gala'
  - var confLabel     = locale === 'en' ? 'Afro-Excellence Conference' : locale === 'es' ? 'Conferencia Afro-Excelencia' : 'Conférence Afro-Excellence'
  - var cat = t.projects.categories.histoire

  header.page-header
    .container
      h1 #{cat.title}
      p #{cat.subtitle}

  section.project-detail
    .container
      .project-detail-layout

        .project-desc
          h2.detail-section-title #{aboutLabel}
          p.typed-text(data-text=cat.description)
          if cat.partners && cat.partners.length
            .partners-section
              h3.partners-title #{partnersLabel}
              .partners-grid
                each partner in cat.partners
                  .partner-card
                    if partner.logo
                      img(src=partner.logo alt=partner.name)
                    else
                      .partner-logo-placeholder 🤝
                    span.partner-name #{partner.name}

        .project-photos
          .vintage-cards-row
            //- Carte cliquable qui ouvre la shadowbox
            .vintage-card(id='openAlbum2026' style='cursor:pointer')
              .vintage-card-inner
                .vintage-photo-area
                  img(src='/images/realisations/histoire/Gala/DSC05435.jpg' alt='2026' onerror="this.parentElement.innerHTML='📷'")
                .vintage-card-footer
                  span 2026
              .vintage-card-shine

  //- ── SHADOWBOX ALBUM ──────────────────────────────────────
  .album-backdrop(id='albumBackdrop')
  .album-modal(id='albumModal')
    button.album-close(id='albumClose' type='button') ✕

    //- Vidéo
    .album-video-wrap
      video.album-video(controls)
        source(src=cat.video type='video/mp4')

    //- Section Gala
    .album-section
      h3.album-section-title #{galaLabel}
      .album-grid
        each photo, i in cat.gala || []
          .album-thumb(data-src=photo data-section='gala' data-index=i)
            img(src=photo alt='Gala 2026')

    //- Section Conférence
    .album-section
      h3.album-section-title #{confLabel}
      .album-grid
        each photo, i in cat.conference || []
          .album-thumb(data-src=photo data-section='conference' data-index=i)
            img(src=photo alt='Conférence 2026')

  //- Lightbox photo
  .lightbox(id='lightbox')
    button.lightbox-close(id='lightboxClose') ✕
    button.lightbox-prev(id='lightboxPrev') ‹
    button.lightbox-next(id='lightboxNext') ›
    .lightbox-content(id='lightboxContent')