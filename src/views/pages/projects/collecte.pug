extends ../../layouts/base

block content
  - var aboutLabel    = locale === 'en' ? 'About' : locale === 'es' ? 'Acerca de' : 'À propos'
  - var partnersLabel = locale === 'en' ? 'Our partners' : locale === 'es' ? 'Nuestros socios' : 'Merci à nos partenaires'
  - var cat = t.projects.categories.collecte

  header.page-header
    .container
      h1 #{cat.title}
      p #{cat.subtitle}

  section.project-detail
    .container
      .project-detail-layout

        //- Gauche : description + partenaires
        .project-desc
          h2.detail-section-title #{aboutLabel}
          p.typed-text(data-text=cat.description)
          if cat.partners && cat.partners.length
            .partners-section
              h3.partners-title #{partnersLabel}
              .partners-grid
                each partner in cat.partners
                  .partner-card
                    if partner.logo
                      img(src=partner.logo alt=partner.name)
                    else
                      .partner-logo-placeholder 🤝
                    span.partner-name #{partner.name}

        //- Droite : cartes vintage par édition
        .project-photos
          .vintage-cards-row
            each edition in cat.editions || []
              .vintage-card(data-edition=edition.year style='cursor:pointer')
                .vintage-card-inner
                  .vintage-photo-area
                    img(src=edition.cover alt=edition.year onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'")
                    .coming-soon-card(style='display:none')
                      span.coming-soon-camera 📷
                      .coming-soon-text
                        span À venir
                        span.dots
                          span .
                          span .
                          span .
                  .vintage-card-footer
                    span #{edition.year}
                .vintage-card-shine

  //- Shadowbox par édition
  each edition in cat.editions || []
    .album-backdrop(id=`backdrop-${edition.year}`)
    .album-modal(id=`modal-${edition.year}`)
      button.album-close(data-year=edition.year type='button') ✕
      .album-section
        h3.album-section-title Collecte #{edition.year}
        .album-grid
          each photo, i in edition.photos
            .album-thumb(data-src=photo data-section=`collecte-${edition.year}` data-index=i)
              img(src=photo alt=`Collecte ${edition.year}`)

  //- Lightbox
  .lightbox(id='lightbox')
    button.lightbox-close(id='lightboxClose') ✕
    button.lightbox-prev(id='lightboxPrev') ‹
    button.lightbox-next(id='lightboxNext') ›
    .lightbox-content(id='lightboxContent')